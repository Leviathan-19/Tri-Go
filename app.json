{
  "expo": {
    "name": "Tri GO",
    "slug": "TriGO",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/fonts_tri/LogoTriGo.jpg",
    "splash": {
      "image": "./assets/images/fonts_tri/splashScreen.png",
      "resizeMode": "cover",
      "backgroundColor": "#FFD100"
    },
    "scheme": "trigo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.leviathan19.TriGO"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/fonts_tri/LogoTriGo.jpg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/fonts_tri/splashScreen.png",
          "resizeMode": "cover",
          "backgroundColor": "#FFD100",
          "dark": {
            "backgroundColor": "#FFD100"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "efd3a001-ea85-4d16-9f94-12c822a51275"
      }
    }
  }
}